---
// src/pages/insights/[slug].astro — Detailed Blog Post View
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getAllPosts, getPostBySlug, urlFor } from '../../lib/sanity';
import PortableText from '../../components/PortableText.astro';

const { slug } = Astro.params;
const post = await getPostBySlug(slug);

if (!post) {
  return Astro.redirect('/404');
}

const siteUrl = 'https://ginkvora.com';

const pageTitle = post.seoTitle || `${post.title} | GINKVORA Insights`;
const pageDescription = post.seoDescription || post.excerpt;

// Article (BlogPosting) Schema
const blogSchema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": post.title,
  "description": pageDescription,
  "image": urlFor(post.coverImage).url(),
  "datePublished": post.publishedAt || new Date().toISOString(),
  "dateModified": post.updatedAt || post.publishedAt || new Date().toISOString(),
  "url": `${siteUrl}/insights/${slug}`,
  "inLanguage": "en-US",
  "author": {
    "@type": post.author ? "Person" : "Organization",
    "name": post.author?.name || "GINKVORA",
    "url": siteUrl
  },
  "publisher": {
    "@type": "Organization",
    "name": "GINKVORA",
    "logo": {
      "@type": "ImageObject",
      "url": `${siteUrl}/images/logo.svg`
    }
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": `${siteUrl}/insights/${slug}`
  }
};

// FAQ Schema if faqItems exist
const faqSchema = post.faqItems && post.faqItems.length > 0 ? {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": post.faqItems.map((item: any) => ({
    "@type": "Question",
    "name": item.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.answer
    }
  }))
} : null;

// BreadcrumbList Schema
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": siteUrl },
    { "@type": "ListItem", "position": 2, "name": "Insights", "item": `${siteUrl}/insights` },
    { "@type": "ListItem", "position": 3, "name": post.title, "item": `${siteUrl}/insights/${slug}` }
  ]
};
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
>
  <script type="application/ld+json" set:html={JSON.stringify(blogSchema)} slot="head" />
  {faqSchema && <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} slot="head" />}
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} slot="head" />

  <main class="insight-detail bg-noise">
    <div class="container article-container">
      <!-- Breadcrumbs -->
      <nav class="breadcrumbs" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span class="crumb-separator">/</span>
        <a href="/insights">Insights</a>
        <span class="crumb-separator">/</span>
        <span class="crumb-active">Article</span>
      </nav>

      <!-- Article Header -->
      <header class="article-header">
        <div class="article-meta">
          <time datetime={post.publishedAt}>
            {post.publishedAt ? new Date(post.publishedAt).toLocaleDateString('en-US', {
              year: 'numeric',
              month: 'long',
              day: 'numeric'
            }) : 'May 21, 2026'}
          </time>
          {post.readTime && (
            <>
              <span class="meta-dot">·</span>
              <span>{post.readTime} min read</span>
            </>
          )}
          {post.author && (
            <>
              <span class="meta-dot">·</span>
              <span>By {post.author.name}{post.author.credentials ? `, ${post.author.credentials}` : ''}</span>
            </>
          )}
        </div>

        <h1 class="article-title">{post.title}</h1>

        {post.tags && post.tags.length > 0 && (
          <div class="article-tags">
            {post.tags.map((tag) => (
              <span class="badge badge--gold">{tag}</span>
            ))}
          </div>
        )}
      </header>

      <!-- Cover Image -->
      <div class="article-cover glass">
        <picture style="display: contents;">
          <source srcset={urlFor(post.coverImage).width(1200).format('avif').url()} type="image/avif" />
          <source srcset={urlFor(post.coverImage).width(1200).format('webp').url()} type="image/webp" />
          <img
            src={urlFor(post.coverImage).width(1200).url()}
            alt={post.title}
            class="cover-img"
            fetchpriority="high"
            loading="eager"
          />
        </picture>
      </div>

      <!-- Article Body -->
      <article class="article-body">
        {post.body ? (
          <PortableText value={post.body} />
        ) : (
          <p>{post.excerpt}</p>
        )}
      </article>

      <!-- Related Product Callout -->
      {post.relatedProduct && (
        <section class="related-product-callout glass" aria-label="Related Product">
          <div class="related-product-header">
            <span class="purity-badge">Related Ingredient</span>
          </div>
          <div class="related-product-body">
            <div class="related-product-info">
              <h3 class="related-product-name">{post.relatedProduct.name}</h3>
              {post.relatedProduct.purity && <span class="purity-badge" style="margin-left: 0.5rem;">{post.relatedProduct.purity}</span>}
              <p class="related-product-desc">{post.relatedProduct.shortDescription}</p>
            </div>
            <a href={`/products/${post.relatedProduct.slug}`} class="btn btn--gold btn--sm">
              View Specification & Request COA
            </a>
          </div>
        </section>
      )}

      <!-- FAQ Accordion/List -->
      {post.faqItems && post.faqItems.length > 0 && (
        <section class="article-faqs glass" aria-labelledby="faqs-title">
          <h2 id="faqs-title" class="faqs-heading">Frequently Asked Questions</h2>
          <div class="faq-list">
            {post.faqItems.map((item) => (
              <div class="faq-item">
                <h3 class="faq-question">{item.question}</h3>
                <p class="faq-answer">{item.answer}</p>
              </div>
            ))}
          </div>
        </section>
      )}

      <!-- Bottom CTAs -->
      <section class="post-cta glass" aria-label="RFQ Action">
        <div class="cta-content">
          <h3>Need Premium Grade Ingredients?</h3>
          <p>Request documentation, COAs, or sample shipments for any active plant constituent directly from our commercial desk.</p>
        </div>
        <a href="/contact" class="btn btn--gold">
          Request Quotation / Sample
        </a>
      </section>
    </div>
  </main>
</BaseLayout>

<style>
  .insight-detail {
    padding-block: 7rem var(--space-4xl);
  }

  .article-container {
    max-width: 800px;
  }

  .breadcrumbs {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    color: var(--color-text-muted);
    margin-bottom: 2.5rem;
  }

  .crumb-separator {
    color: var(--color-text-muted);
  }

  .crumb-active {
    color: var(--color-primary-light);
    font-weight: 500;
  }

  /* ── Header ── */
  .article-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .article-meta {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    margin-bottom: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .meta-dot {
    margin-inline: 0.5rem;
  }

  .article-title {
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 700;
    line-height: 1.15;
    margin-bottom: 1.25rem;
    color: var(--color-text);
  }

  .article-tags {
    display: flex;
    gap: 0.5rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  /* ── Cover Image ── */
  .article-cover {
    width: 100%;
    aspect-ratio: 16/9;
    overflow: hidden;
    margin-bottom: 3.5rem;
    border-color: rgba(212, 166, 84, 0.15) !important;
  }

  .cover-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* ── Body Content ── */
  .article-body {
    font-size: 1.0625rem;
    line-height: 1.85;
    color: var(--color-text-secondary);
  }

  .article-body :global(p) {
    margin-bottom: 1.5rem;
  }

  .article-body :global(h2), .article-body :global(h3) {
    color: var(--color-text);
    margin-block: 2.5rem 1rem;
    font-family: var(--font-display);
    font-weight: 600;
  }

  .article-body :global(h2) { font-size: 1.75rem; }
  .article-body :global(h3) { font-size: 1.375rem; }

  .article-body :global(ul) {
    margin-bottom: 1.5rem;
    padding-left: 1.5rem;
    list-style: disc;
  }

  .article-body :global(li) {
    margin-bottom: 0.5rem;
  }

  /* ── Bottom CTA ── */
  .post-cta {
    margin-top: 4.5rem;
    padding: 2rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    border-radius: var(--radius-lg);
    border-color: rgba(212, 166, 84, 0.2) !important;
  }

  @media (max-width: 640px) {
    .post-cta {
      flex-direction: column;
      text-align: center;
      gap: 1.25rem;
    }
  }

  .cta-content h3 {
    font-size: 1.375rem;
    color: var(--color-primary-light);
    margin-bottom: 0.25rem;
  }

  .cta-content p {
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    line-height: 1.5;
  }

  .post-cta .btn {
    flex-shrink: 0;
  }

  /* ── Related Product Callout ── */
  .related-product-callout {
    margin-top: 4rem;
    padding: 2rem;
    border-radius: var(--radius-lg);
    border: 1px solid rgba(212, 166, 84, 0.15) !important;
    background: rgba(212, 166, 84, 0.02);
  }
  
  .related-product-header {
    margin-bottom: 1rem;
  }
  
  .related-product-body {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
  }
  
  @media (max-width: 640px) {
    .related-product-body {
      flex-direction: column;
      align-items: flex-start;
      gap: 1.25rem;
    }
  }
  
  .related-product-info {
    flex: 1;
  }
  
  .related-product-name {
    font-size: 1.5rem;
    font-family: var(--font-display);
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: 0.5rem;
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
  }
  
  .purity-badge {
    display: inline-block;
    font-size: 0.75rem;
    font-family: var(--font-mono);
    color: var(--color-primary-light);
    border: 1px solid rgba(212, 166, 84, 0.3);
    padding: 0.125rem 0.5rem;
    border-radius: 9999px;
    margin-bottom: 0.5rem;
  }
  
  .related-product-desc {
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin-bottom: 0;
  }
  
  /* ── FAQs ── */
  .article-faqs {
    margin-top: 4rem;
    padding: 2.5rem;
    border-radius: var(--radius-lg);
    border: 1px solid rgba(255, 255, 255, 0.05) !important;
  }
  
  .faqs-heading {
    font-size: 1.75rem !important;
    font-family: var(--font-display);
    color: var(--color-text);
    margin-top: 0 !important;
    margin-bottom: 1.75rem !important;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    padding-bottom: 0.75rem;
  }
  
  .faq-list {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  
  .faq-item {
    border-bottom: 1px solid rgba(255, 255, 255, 0.03);
    padding-bottom: 1.25rem;
  }
  
  .faq-item:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }
  
  .faq-question {
    font-size: 1.125rem !important;
    font-weight: 600;
    color: var(--color-primary-light);
    margin: 0 0 0.5rem 0 !important;
  }
  
  .faq-answer {
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin: 0 !important;
  }
</style>
