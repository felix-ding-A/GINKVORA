---
// src/components/PortableText.astro — Simple Portable Text and Markdown renderer
import { marked } from 'marked';

interface Props {
  value: any;
}

const { value } = Astro.props;

let htmlContent = '';

// Normalize text: replace escaped double backslash \\n with actual \n
const normalizeText = (text: string): string => {
  if (!text) return '';
  return text.replace(/\\n/g, '\n');
};

if (typeof value === 'string') {
  htmlContent = await marked.parse(normalizeText(value));
} else if (Array.isArray(value)) {
  const parsedBlocks = await Promise.all(
    value.map(async (block) => {
      if (!block) return '';
      
      if (block._type === 'block') {
        let text = block.children?.map((c: any) => c.text).join('') || '';
        text = normalizeText(text);

        // Check if block has native list properties
        const isNativeList = !!block.listItem;

        // If the text contains block-level markdown markers
        const hasBlockMarkdown = text.includes('\n') || text.trim().startsWith('- ') || text.trim().startsWith('* ') || text.trim().startsWith('1. ');

        if (hasBlockMarkdown && !isNativeList) {
          // Parse the whole block as full markdown (includes lists, paragraphs, etc.)
          return await marked.parse(text);
        }

        // Otherwise parse inline markdown rules (bold, italic, links, etc.)
        const inlineHtml = await marked.parseInline(text);

        if (block.style === 'h1') return `<h1>${inlineHtml}</h1>`;
        if (block.style === 'h2') return `<h2>${inlineHtml}</h2>`;
        if (block.style === 'h3') return `<h3>${inlineHtml}</h3>`;
        if (block.style === 'h4') return `<h4>${inlineHtml}</h4>`;
        if (block.style === 'blockquote') return `<blockquote>${inlineHtml}</blockquote>`;
        if (block.listItem === 'bullet') return `<li>${inlineHtml}</li>`;
        if (block.listItem === 'number') return `<li>${inlineHtml}</li>`;

        return `<p>${inlineHtml}</p>`;
      }
      
      return '';
    })
  );

  htmlContent = parsedBlocks.join('');
  
  // Wrap contiguous <li> tags in <ul> or <ol>
  htmlContent = htmlContent.replace(/(<li>.*?<\/li>)+/g, (match) => `<ul>${match}</ul>`);
} else if (value) {
  htmlContent = `<p>${JSON.stringify(value)}</p>`;
}
---

<div class="portable-text" set:html={htmlContent} />

<style>
  .portable-text {
    line-height: 1.8;
  }
  .portable-text :global(p) {
    margin-bottom: 1.25rem;
  }
  .portable-text :global(h2) {
    font-size: 1.75rem;
    color: var(--color-primary-light);
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    font-family: var(--font-display);
    font-weight: 600;
  }
  .portable-text :global(h3) {
    font-size: 1.5rem;
    color: var(--color-primary-light);
    margin-top: 2rem;
    margin-bottom: 0.5rem;
    font-family: var(--font-display);
    font-weight: 600;
  }
  .portable-text :global(ul), .portable-text :global(ol) {
    margin-bottom: 1.25rem;
    padding-left: 1.5rem;
  }
  .portable-text :global(li) {
    margin-bottom: 0.5rem;
    list-style: inherit;
  }
  .portable-text :global(strong) {
    color: var(--color-primary-light);
    font-weight: 600;
  }
  .portable-text :global(blockquote) {
    border-left: 4px solid var(--color-primary);
    padding-left: 1rem;
    margin-inline: 0;
    margin-bottom: 1.25rem;
    color: var(--color-text-secondary);
    font-style: italic;
  }
</style>
