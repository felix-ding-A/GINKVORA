---
// FeaturedIngredientsSection.astro — Key ingredients spotlight
import { useTranslations, getLocalePath } from '../../i18n/utils';
import type { Lang } from '../../i18n/utils';
interface Props { lang?: string; }
const { lang = 'en' } = Astro.props;
const t = useTranslations(lang as Lang);
const lp = (path: string) => getLocalePath(lang as Lang, path);

// Slugs match actual Sanity CMS slugs confirmed from sitemap
const ingredients = [
  {
    name: 'PQQ',
    fullName: 'Pyrroloquinoline Quinone',
    category: 'Health Supplement',
    purity: '≥ 99%',
    description: 'A potent redox cofactor that supports mitochondrial biogenesis, neurological health, and cellular energy production.',
    benefits: ['Mitochondrial Health', 'Cognitive Function', 'Antioxidant', 'Longevity'],
    color: '#d4a654',
    slug: 'pqq-disodium-salt',
  },
  {
    name: 'NMN',
    fullName: 'Nicotinamide Mononucleotide',
    category: 'Health Supplement',
    purity: '≥ 99%',
    description: 'Direct precursor to NAD+, supporting cellular metabolism, DNA repair, and healthy aging pathways.',
    benefits: ['NAD+ Precursor', 'Anti-Aging', 'Metabolism', 'DNA Repair'],
    color: '#e07830',
    slug: 'nmn-nicotinamide-mononucleotide',
  },
  {
    name: 'Glabridin',
    fullName: 'Licorice Root Extract',
    category: 'Cosmetic Active',
    purity: '≥ 40%',
    description: 'Powerful skin-brightening and anti-inflammatory active derived from licorice root, widely used in premium skincare formulations.',
    benefits: ['Skin Brightening', 'Anti-Inflammatory', 'UV Protection', 'Antioxidant'],
    color: '#f0c878',
    slug: 'glabridin',
  },
  {
    name: 'EGCG',
    fullName: 'Epigallocatechin Gallate',
    category: 'Dual-Use',
    purity: '≥ 98%',
    description: 'The most bioactive catechin from green tea with exceptional antioxidant capacity, used in both supplements and cosmetics.',
    benefits: ['Antioxidant', 'Anti-Aging', 'Weight Management', 'Skin Health'],
    color: '#c8965a',
    slug: 'egcg-epigallocatechin-gallate',
  },
  {
    name: 'Luteolin',
    fullName: 'Natural Flavonoid',
    category: 'Health Supplement',
    purity: '≥ 98%',
    description: 'A naturally occurring flavonoid with strong anti-inflammatory, neuroprotective, and immune-modulating properties.',
    benefits: ['Anti-Inflammatory', 'Neuroprotection', 'Immunity', 'Antioxidant'],
    color: '#e09040',
    slug: 'luteolin',
  },
  {
    name: 'Flavone',
    fullName: '2-Phenyl-4H-chromen-4-one',
    category: 'Health Supplement',
    purity: '≥ 99%',
    description: 'A parent compound of the flavonoid class with broad biological activities including antimicrobial and anti-cancer properties.',
    benefits: ['Anticancer Research', 'Antimicrobial', 'Anti-Inflammatory', 'Antioxidant'],
    color: '#b87840',
    slug: 'flavone',
  },
];
---

<section class="ingredients-section section" id="key-ingredients">
  <div class="container">
    <!-- Header -->
    <div class="section-header reveal">
      <span class="section-label">{t('featured.label')}</span>
      <h2 class="section-title">
        {t('featured.title_1')}<br/>
        <span class="gradient-text">{t('featured.title_2')}</span>
      </h2>
      <p class="section-desc">
        {t('featured.desc')}
      </p>
    </div>

    <!-- Ingredients grid -->
    <div class="ingredients-grid">
      {ingredients.map((ing, idx) => (
        <a
          href={lp(`/products/${ing.slug}`)}
          class={`ingredient-card glass reveal reveal-delay-${(idx % 4) + 1}`}
          style={`--ing-color: ${ing.color};`}
          id={`ingredient-${ing.name.toLowerCase()}`}
          aria-label={`${ing.name} — ${ing.fullName}`}
        >
          <!-- Top accent line -->
          <div class="card-accent-line"></div>

          <!-- Header -->
          <div class="card-header">
            <div class="card-name-group">
              <h3 class="card-name">{ing.name}</h3>
              <span class="card-full-name">{ing.fullName}</span>
            </div>
            <span class="card-category">{ing.category}</span>
          </div>

          <!-- Purity indicator -->
          <div class="card-purity">
            <span class="purity-label">{t('products.purity_label')}</span>
            <div class="purity-bar-wrap">
              <div class="purity-bar" style={`--purity: ${parseInt(ing.purity) / 100};`}></div>
            </div>
            <span class="purity-number">{ing.purity}</span>
          </div>

          <!-- Description -->
          <p class="card-desc">{ing.description}</p>

          <!-- Benefits tags -->
          <div class="card-benefits">
            {ing.benefits.map((b) => (
              <span class="benefit-tag">{b}</span>
            ))}
          </div>

          <!-- Link -->
          <div class="card-link">
            {t('products.view_details')}
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </div>
        </a>
      ))}
    </div>

    <div class="ingredients-cta reveal">
      <a href={lp('/products')} class="btn btn--primary" id="view-all-ingredients-btn">
        {t('featured.cta')}
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
    </div>
  </div>
</section>

<style>
  .ingredients-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
    margin-bottom: 2.5rem;
  }

  .ingredient-card {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding: 1.625rem;
    text-decoration: none;
    background: var(--color-surface) !important;
    border: 1px solid var(--color-border) !important;
    transition: all 0.3s ease;
    overflow: hidden;
  }

  .ingredient-card::after {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at 50% 0%, color-mix(in srgb, var(--ing-color) 6%, transparent) 0%, transparent 70%);
    opacity: 0;
    transition: opacity 0.3s ease;
    pointer-events: none;
  }

  .ingredient-card:hover {
    border-color: color-mix(in srgb, var(--ing-color) 30%, transparent) !important;
    transform: translateY(-4px);
    box-shadow: 0 16px 48px rgba(0,0,0,0.4);
  }

  .ingredient-card:hover::after { opacity: 1; }

  .card-accent-line {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: var(--ing-color);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.4s ease;
  }

  .ingredient-card:hover .card-accent-line {
    transform: scaleX(1);
  }

  /* Header */
  .card-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 0.5rem;
  }

  .card-name-group {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .card-name {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-text);
    line-height: 1;
    transition: color 0.3s ease;
  }

  .ingredient-card:hover .card-name {
    color: var(--ing-color);
  }

  .card-full-name {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    font-style: italic;
    font-family: var(--font-display);
  }

  .card-category {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    background: var(--color-surface-2);
    padding: 0.2rem 0.5rem;
    border-radius: var(--radius-full);
    white-space: nowrap;
    border: 1px solid var(--color-border);
    flex-shrink: 0;
  }

  /* Purity bar */
  .card-purity {
    display: flex;
    align-items: center;
    gap: 0.625rem;
  }

  .purity-label {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    white-space: nowrap;
  }

  .purity-bar-wrap {
    flex: 1;
    height: 4px;
    background: var(--color-surface-2);
    border-radius: 2px;
    overflow: hidden;
  }

  .purity-bar {
    height: 100%;
    width: calc(var(--purity, 0.99) * 100%);
    background: linear-gradient(90deg, var(--ing-color), color-mix(in srgb, var(--ing-color) 70%, white));
    border-radius: 2px;
    transition: width 1s ease;
  }

  .purity-number {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--ing-color);
    white-space: nowrap;
  }

  /* Description */
  .card-desc {
    font-size: 0.9rem;
    line-height: 1.65;
    color: var(--color-text-secondary);
    flex: 1;
  }

  /* Benefits */
  .card-benefits {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
  }

  .benefit-tag {
    font-size: 0.7rem;
    font-weight: 500;
    color: var(--color-text-muted);
    background: var(--color-surface-2);
    padding: 0.2rem 0.5rem;
    border-radius: var(--radius-full);
    border: 1px solid var(--color-border);
  }

  /* Link */
  .card-link {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--ing-color);
    opacity: 0;
    transform: translateY(4px);
    transition: all 0.3s ease;
  }

  .ingredient-card:hover .card-link {
    opacity: 1;
    transform: translateY(0);
  }

  .ingredients-cta {
    text-align: center;
  }

  @media (max-width: 1024px) {
    .ingredients-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 640px) {
    .ingredients-grid { grid-template-columns: 1fr; }
  }
</style>
