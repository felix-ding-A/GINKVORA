---
// src/components/PortableText.astro — Simple Portable Text and Markdown renderer
import { marked } from 'marked';

interface Props {
  value: any;
}

const { value } = Astro.props;

let htmlContent = '';

if (typeof value === 'string') {
  htmlContent = await marked.parse(value);
} else if (Array.isArray(value)) {
  htmlContent = value.map((block) => {
    if (!block) return '';
    
    if (block._type === 'block') {
      const text = block.children?.map((c: any) => c.text).join('') || '';
      
      if (block.style === 'h1') return `<h1>${text}</h1>`;
      if (block.style === 'h2') return `<h2>${text}</h2>`;
      if (block.style === 'h3') return `<h3>${text}</h3>`;
      if (block.style === 'h4') return `<h4>${text}</h4>`;
      if (block.style === 'blockquote') return `<blockquote>${text}</blockquote>`;
      
      return `<p>${text}</p>`;
    }
    
    return '';
  }).join('');
} else if (value) {
  htmlContent = `<p>${JSON.stringify(value)}</p>`;
}
---

<div class="portable-text" set:html={htmlContent} />

<style>
  .portable-text {
    line-height: 1.8;
  }
  .portable-text :global(p) {
    margin-bottom: 1.25rem;
  }
  .portable-text :global(h2) {
    font-size: 1.75rem;
    color: var(--color-primary-light);
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    font-family: var(--font-display);
    font-weight: 600;
  }
  .portable-text :global(h3) {
    font-size: 1.5rem;
    color: var(--color-primary-light);
    margin-top: 2rem;
    margin-bottom: 0.5rem;
    font-family: var(--font-display);
    font-weight: 600;
  }
  .portable-text :global(ul), .portable-text :global(ol) {
    margin-bottom: 1.25rem;
    padding-left: 1.5rem;
  }
  .portable-text :global(li) {
    margin-bottom: 0.5rem;
    list-style: inherit;
  }
  .portable-text :global(strong) {
    color: var(--color-primary-light);
    font-weight: 600;
  }
  .portable-text :global(blockquote) {
    border-left: 4px solid var(--color-primary);
    padding-left: 1rem;
    margin-inline: 0;
    margin-bottom: 1.25rem;
    color: var(--color-text-secondary);
    font-style: italic;
  }
</style>
