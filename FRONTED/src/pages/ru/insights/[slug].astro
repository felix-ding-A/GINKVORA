---
// src/pages/ru/insights/[slug].astro — Russian blog post detail page
export const prerender = true;
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getAllPosts, getPostBySlug, urlFor, getLocalizedField } from '../../../lib/sanity';
import PortableText from '../../../components/PortableText.astro';
import { useTranslations, getLocalePath } from '../../../i18n/utils';

const lang = 'ru';
const t = useTranslations(lang);

export async function getStaticPaths() {
  const posts = await getAllPosts(100);
  return posts.map((p: any) => ({ params: { slug: p.slug } }));
}

const { slug } = Astro.params;
const post = await getPostBySlug(slug);

if (!post) {
  return Astro.redirect('/404');
}

const siteUrl = 'https://ginkvora.com';

// Localized fields — fall back to English if no Russian available
const localTitle      = (getLocalizedField(post, 'title', lang)         ?? post.title)         as string;
const localExcerpt    = (getLocalizedField(post, 'excerpt', lang)        ?? post.excerpt)        as string | undefined;
const localBody       = getLocalizedField(post, 'body', lang)            ?? post.body;
const localSeoTitle   = (getLocalizedField(post, 'seoTitle', lang)       ?? post.seoTitle)       as string | undefined;
const localSeoDesc    = (getLocalizedField(post, 'seoDescription', lang) ?? post.seoDescription) as string | undefined;
const localRelatedShort = post.relatedProduct
  ? ((getLocalizedField(post.relatedProduct, 'shortDescription', lang) ?? post.relatedProduct.shortDescription) as string | undefined)
  : undefined;

const pageTitle       = localSeoTitle  || `${localTitle} | GINKVORA`;
const pageDescription = localSeoDesc   || localExcerpt;

const blogSchema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": localTitle,
  "description": pageDescription,
  "image": urlFor(post.coverImage).url(),
  "datePublished": post.publishedAt || new Date().toISOString(),
  "dateModified": post.updatedAt || post.publishedAt || new Date().toISOString(),
  "url": `${siteUrl}/ru/insights/${slug}`,
  "inLanguage": "ru-RU",
  "author": {
    "@type": post.author ? "Person" : "Organization",
    "name": post.author?.name || "GINKVORA",
    "url": siteUrl
  },
  "publisher": {
    "@type": "Organization",
    "name": "GINKVORA",
    "logo": { "@type": "ImageObject", "url": `${siteUrl}/images/logo.svg` }
  },
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Главная", "item": `${siteUrl}/ru` },
    { "@type": "ListItem", "position": 2, "name": "Блог",   "item": `${siteUrl}/ru/insights` },
    { "@type": "ListItem", "position": 3, "name": localTitle, "item": `${siteUrl}/ru/insights/${slug}` },
  ],
};
---

<BaseLayout
  lang={lang}
  title={pageTitle}
  description={pageDescription}
>
  <script type="application/ld+json" set:html={JSON.stringify(blogSchema)} slot="head" />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} slot="head" />

  <main class="insight-detail bg-noise">
    <div class="container article-container">
      <!-- Breadcrumbs -->
      <nav class="breadcrumbs" aria-label="Хлебные крошки">
        <a href="/ru">Главная</a>
        <span class="crumb-separator">/</span>
        <a href="/ru/insights">Блог</a>
        <span class="crumb-separator">/</span>
        <span class="crumb-active">Статья</span>
      </nav>

      <!-- Article Header -->
      <header class="article-header">
        <div class="article-meta">
          <time datetime={post.publishedAt}>
            {post.publishedAt ? new Date(post.publishedAt).toLocaleDateString('ru-RU', {
              year: 'numeric', month: 'long', day: 'numeric'
            }) : ''}
          </time>
          {post.readTime && (
            <>
              <span class="meta-dot">·</span>
              <span>{post.readTime} {t('insights.min_read')}</span>
            </>
          )}
          {post.author && (
            <>
              <span class="meta-dot">·</span>
              <span>{t('insights.by_author')} {post.author.name}{post.author.credentials ? `, ${post.author.credentials}` : ''}</span>
            </>
          )}
        </div>

        <h1 class="article-title">{localTitle}</h1>

        {post.tags && post.tags.length > 0 && (
          <div class="article-tags">
            {post.tags.map((tag: string) => (
              <span class="badge badge--gold">{tag}</span>
            ))}
          </div>
        )}
      </header>

      <!-- Cover Image -->
      <div class="article-cover glass">
        <picture style="display: contents;">
          <source srcset={urlFor(post.coverImage).width(1200).format('webp').url()} type="image/webp" />
          <img
            src={urlFor(post.coverImage).width(1200).url()}
            alt={localTitle}
            class="cover-img"
            fetchpriority="high"
            loading="eager"
          />
        </picture>
      </div>

      <!-- Article Body -->
      <article class="article-body">
        {localBody ? (
          <PortableText value={localBody} />
        ) : (
          <p>{localExcerpt}</p>
        )}
      </article>

      <!-- Related Product Callout -->
      {post.relatedProduct && (
        <section class="related-product-callout glass" aria-label="Связанный продукт">
          <div class="related-product-header">
            <span class="purity-badge">Связанный ингредиент</span>
          </div>
          <div class="related-product-body">
            <div class="related-product-info">
              <h3 class="related-product-name">
                {post.relatedProduct.name}
                {post.relatedProduct.purity && <span class="purity-badge" style="margin-left: 0.5rem;">{post.relatedProduct.purity}</span>}
              </h3>
              <p class="related-product-desc">{localRelatedShort}</p>
            </div>
            <a href={`/ru/products/${post.relatedProduct.slug}`} class="btn btn--gold btn--sm">
              Характеристики и запрос COA →
            </a>
          </div>
        </section>
      )}

      <!-- Bottom CTA -->
      <section class="post-cta glass" aria-label="Запросить КП">
        <div class="cta-content">
          <h3>{t('common.contact_cta')}</h3>
          <p>{t('common.contact_cta_sub')}</p>
        </div>
        <a href="/ru/contact" class="btn btn--gold">
          {t('common.contact_cta_btn')}
        </a>
      </section>
    </div>
  </main>
</BaseLayout>

<style>
  .insight-detail { padding-block: 7rem var(--space-4xl); }
  .article-container { max-width: 800px; }

  .breadcrumbs { display: flex; align-items: center; gap: 0.5rem; font-size: 0.875rem; color: var(--color-text-muted); margin-bottom: 2.5rem; }
  .crumb-separator { color: var(--color-text-muted); }
  .crumb-active { color: var(--color-primary-light); font-weight: 500; }

  .article-header { text-align: center; margin-bottom: 3rem; }
  .article-meta { font-family: var(--font-mono); font-size: 0.8125rem; color: var(--color-text-muted); margin-bottom: 0.75rem; text-transform: uppercase; letter-spacing: 0.05em; }
  .meta-dot { margin-inline: 0.5rem; }
  .article-title { font-size: clamp(2rem, 5vw, 3rem); font-weight: 700; line-height: 1.15; margin-bottom: 1.25rem; color: var(--color-text); }
  .article-tags { display: flex; gap: 0.5rem; justify-content: center; flex-wrap: wrap; }

  .article-cover { width: 100%; aspect-ratio: 16/9; overflow: hidden; margin-bottom: 3.5rem; border-color: rgba(212,166,84,0.15) !important; }
  .cover-img { width: 100%; height: 100%; object-fit: cover; }

  .article-body { font-size: 1.0625rem; line-height: 1.85; color: var(--color-text-secondary); }
  .article-body :global(p) { margin-bottom: 1.5rem; }
  .article-body :global(h2), .article-body :global(h3) { color: var(--color-text); margin-block: 2.5rem 1rem; font-family: var(--font-display); font-weight: 600; }
  .article-body :global(h2) { font-size: 1.75rem; }
  .article-body :global(h3) { font-size: 1.375rem; }
  .article-body :global(ul) { margin-bottom: 1.5rem; padding-left: 1.5rem; list-style: disc; }
  .article-body :global(li) { margin-bottom: 0.5rem; }

  .post-cta { margin-top: 4.5rem; padding: 2rem; display: flex; align-items: center; justify-content: space-between; gap: 2rem; border-radius: var(--radius-lg); border-color: rgba(212,166,84,0.2) !important; }
  @media (max-width: 640px) { .post-cta { flex-direction: column; text-align: center; gap: 1.25rem; } }
  .cta-content h3 { font-size: 1.375rem; color: var(--color-primary-light); margin-bottom: 0.25rem; }
  .cta-content p { font-size: 0.875rem; color: var(--color-text-secondary); line-height: 1.5; }
  .post-cta .btn { flex-shrink: 0; }

  .related-product-callout { margin-top: 4rem; padding: 2rem; border-radius: var(--radius-lg); border: 1px solid rgba(212,166,84,0.15) !important; }
  .related-product-header { margin-bottom: 1rem; }
  .related-product-body { display: flex; align-items: center; justify-content: space-between; gap: 2rem; }
  @media (max-width: 640px) { .related-product-body { flex-direction: column; align-items: flex-start; gap: 1.25rem; } }
  .related-product-info { flex: 1; }
  .related-product-name { font-size: 1.5rem; font-family: var(--font-display); font-weight: 600; color: var(--color-text); margin-bottom: 0.5rem; display: inline-flex; align-items: center; gap: 0.75rem; }
  .purity-badge { display: inline-block; font-size: 0.75rem; font-family: var(--font-mono); color: var(--color-primary-light); border: 1px solid rgba(212,166,84,0.3); padding: 0.125rem 0.5rem; border-radius: 9999px; margin-bottom: 0.5rem; }
  .related-product-desc { font-size: 0.9375rem; color: var(--color-text-secondary); line-height: 1.6; margin-bottom: 0; }
</style>
