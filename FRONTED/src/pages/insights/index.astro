---
// src/pages/insights/index.astro — B2B Industry Insights & Ingredient Research Blog
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getAllPosts, urlFor } from '../../lib/sanity';

const posts = await getAllPosts();
const siteUrl = 'https://ginkvora.com';

// Breadcrumb structured data
const breadcrumbsSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": siteUrl
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Insights",
      "item": `${siteUrl}/insights`
    }
  ]
};

// ItemList structured data
const itemListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "GINKVORA Industry Insights",
  "description": "Scientific research updates, market trends, and regulatory updates on plant active ingredients.",
  "url": `${siteUrl}/insights`,
  "numberOfItems": posts.length,
  "itemListElement": posts.map((post, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "url": `${siteUrl}/insights/${post.slug}`,
    "name": post.title,
  }))
};
---

<BaseLayout
  title="B2B Plant Extract Insights & Scientific Research | GINKVORA"
  description="Stay informed with scientific research updates, market trends, and regulatory updates on plant active ingredients (PQQ, NMN, Glabridin)."
>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbsSchema)} slot="head" />
  <script type="application/ld+json" set:html={JSON.stringify(itemListSchema)} slot="head" />
  <main class="insights-page bg-noise">
    <!-- Header banner -->
    <header class="page-banner" aria-label="Page Header">
      <div class="banner-gradient"></div>
      <div class="container banner-content">
        <span class="section-label">Industry Insights</span>
        <h1 class="banner-title">Scientific & Market Research</h1>
        <p class="banner-desc">
          In-depth technical spotlights, scientific whitepapers, and regulatory updates for health brand formulary and procurement officers.
        </p>
      </div>
    </header>

    <!-- Blog Grid -->
    <div class="container insights-container">
      <section class="insights-grid" aria-label="Blog posts list">
        {posts.map((post) => (
          <article class="blog-card glass reveal">
            <div class="card-image-box">
              <img
                src={urlFor(post.coverImage).url()}
                alt={post.title}
                loading="lazy"
                class="card-img"
              />
              {post.tags && post.tags.length > 0 && (
                <span class="card-tag">{post.tags[0]}</span>
              )}
            </div>

            <div class="card-body">
              <div class="card-meta">
                <time datetime={post.publishedAt}>
                  {post.publishedAt ? new Date(post.publishedAt).toLocaleDateString('en-US', {
                    year: 'numeric',
                    month: 'short',
                    day: 'numeric'
                  }) : 'May 2026'}
                </time>
                {post.readTime && (
                  <>
                    <span class="meta-dot">·</span>
                    <span>{post.readTime} min read</span>
                  </>
                )}
              </div>

              <h2 class="card-title">
                <a href={`/insights/${post.slug}`}>{post.title}</a>
              </h2>

              <p class="card-excerpt">{post.excerpt}</p>

              <div class="card-footer">
                <a href={`/insights/${post.slug}`} class="read-more">
                  Read Article
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                    <line x1="5" y1="12" x2="19" y2="12"/>
                    <polyline points="12 5 19 12 12 19"/>
                  </svg>
                </a>
              </div>
            </div>
          </article>
        ))}
      </section>
    </div>
  </main>
</BaseLayout>

<style>
  .insights-page {
    padding-bottom: var(--space-4xl);
  }

  /* ── Banner ── */
  .page-banner {
    position: relative;
    padding-block: 8rem 4rem;
    overflow: hidden;
    background: linear-gradient(135deg, #030201 0%, #0c0804 50%, #060503 100%);
    border-bottom: 1px solid var(--color-border);
  }

  .banner-gradient {
    position: absolute;
    inset: 0;
    background: radial-gradient(circle 35% 50% at 75% 20%, rgba(212, 166, 84, 0.08) 0%, transparent 100%);
  }

  .banner-title {
    font-size: clamp(2.25rem, 5vw, 3.5rem);
    font-weight: 700;
    margin-top: 0.5rem;
    color: var(--color-text);
  }

  .banner-desc {
    max-width: 600px;
    margin-top: 1rem;
    color: var(--color-text-secondary);
    font-size: 1.0625rem;
  }

  /* ── Grid ── */
  .insights-container {
    margin-top: -2rem;
    position: relative;
    z-index: var(--z-float);
  }

  .insights-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }

  @media (max-width: 1024px) {
    .insights-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 768px) {
    .insights-grid { grid-template-columns: 1fr; }
  }

  /* ── Card ── */
  .blog-card {
    display: flex;
    flex-direction: column;
    height: 100%;
    overflow: hidden;
    transition: transform var(--transition-base), border-color var(--transition-base), box-shadow var(--transition-base);
    border-color: rgba(212,166,84,0.1) !important;
  }

  .blog-card:hover {
    transform: translateY(-5px);
    border-color: var(--color-border-strong) !important;
    box-shadow: var(--shadow-glow-gold);
  }

  .card-image-box {
    position: relative;
    height: 200px;
    background: var(--color-surface-2);
    overflow: hidden;
  }

  .card-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--transition-slow);
  }

  .blog-card:hover .card-img {
    transform: scale(1.04);
  }

  .card-tag {
    position: absolute;
    top: 0.75rem;
    left: 0.75rem;
    background: var(--color-accent);
    color: #fff;
    font-size: 0.75rem;
    font-weight: 500;
    padding: 0.15rem 0.55rem;
    border-radius: var(--radius-sm);
  }

  .card-body {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    flex-grow: 1;
  }

  .card-meta {
    display: flex;
    align-items: center;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-text-muted);
    margin-bottom: 0.5rem;
  }

  .meta-dot {
    margin-inline: 0.35rem;
  }

  .card-title {
    font-size: 1.375rem;
    font-weight: 600;
    line-height: 1.25;
    margin-bottom: 0.75rem;
  }

  .card-title a {
    color: var(--color-text);
  }

  .card-title a:hover {
    color: var(--color-primary-light);
  }

  .card-excerpt {
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin-bottom: 1.5rem;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card-footer {
    margin-top: auto;
  }

  .read-more {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-primary-light);
    transition: color var(--transition-fast);
  }

  .read-more:hover {
    color: var(--color-accent-light);
  }

  .read-more svg {
    transition: transform var(--transition-fast);
  }

  .read-more:hover svg {
    transform: translateX(3px);
  }
</style>
