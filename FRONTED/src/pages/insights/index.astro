---
// src/pages/insights/index.astro — B2B Industry Insights & Ingredient Research Blog
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getPostsPaginated, urlFor } from '../../lib/sanity';

const siteUrl = 'https://ginkvora.com';
const selectedCategory = Astro.url.searchParams.get('category');
const pageParam = Astro.url.searchParams.get('page');
const currentPage = Math.max(1, pageParam ? parseInt(pageParam, 10) : 1);
const pageSize = 6;

const { posts, total } = await getPostsPaginated({
  category: selectedCategory,
  page: currentPage,
  pageSize,
});

const totalPages = Math.ceil(total / pageSize);

// Helper function to build page URLs while preserving category query params
function getPageHref(pageNum: number) {
  const url = new URL(Astro.url.href);
  url.searchParams.set('page', pageNum.toString());
  return url.pathname + url.search;
}

// Breadcrumb structured data
const breadcrumbsSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": siteUrl
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Insights",
      "item": `${siteUrl}/insights`
    }
  ]
};

// ItemList structured data
const itemListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "GINKVORA Industry Insights",
  "description": "Scientific research updates, market trends, and regulatory updates on plant active ingredients.",
  "url": `${siteUrl}/insights`,
  "numberOfItems": posts.length,
  "itemListElement": posts.map((post, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "url": `${siteUrl}/insights/${post.slug}`,
    "name": post.title,
  }))
};
---

<BaseLayout
  title={selectedCategory ? `${selectedCategory} Insights & Research | GINKVORA` : "B2B Plant Extract Insights & Scientific Research | GINKVORA"}
  description={selectedCategory ? `Browse our expert research, market trends, and quality reports on ${selectedCategory}.` : "Stay informed with scientific research updates, market trends, and regulatory updates on plant active ingredients (PQQ, NMN, Glabridin)."}
>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbsSchema)} slot="head" />
  <script type="application/ld+json" set:html={JSON.stringify(itemListSchema)} slot="head" />
  <main class="insights-page bg-noise">
    <!-- Header banner -->
    <header class="page-banner" aria-label="Page Header">
      <div class="banner-gradient"></div>
      <div class="container banner-content">
        <span class="section-label">Industry Insights</span>
        <h1 class="banner-title">Scientific & Market Research</h1>
        <p class="banner-desc">
          In-depth technical spotlights, scientific whitepapers, and regulatory updates for health brand formulary and procurement officers.
        </p>
      </div>
    </header>

    <!-- Filter bar -->
    <div class="container filter-container">
      <nav class="category-tabs" aria-label="Category filter">
        <a 
          href="/insights" 
          class:list={['category-tab', { 'category-tab--active': !selectedCategory }]}
        >
          All
        </a>
        {['Ingredient Spotlight', 'Formulation Tips', 'Research', 'Quality & Testing', 'Regulatory', 'Market Trends', 'Industry News'].map(cat => {
          const catSlug = cat.toLowerCase().replace(/[^a-z0-9]/g, '');
          const isActive = selectedCategory && selectedCategory.toLowerCase().replace(/[^a-z0-9]/g, '') === catSlug;
          return (
            <a 
              href={`/insights?category=${encodeURIComponent(cat)}`} 
              class:list={['category-tab', { 'category-tab--active': isActive }]}
            >
              {cat}
            </a>
          );
        })}
      </nav>
    </div>

    <!-- Blog Grid -->
    <div class="container insights-container">
      {posts.length > 0 ? (
        <section class="insights-grid" aria-label="Blog posts list">
          {posts.map((post) => (
            <article class="blog-card glass reveal">
              <div class="card-image-box">
                <a href={`/insights/${post.slug}`} class="card-image-link" aria-label={`Read ${post.title}`}>
                  <picture style="display: contents;">
                    <source srcset={urlFor(post.coverImage).width(800).format('webp').url()} type="image/webp" />
                    <img
                      src={urlFor(post.coverImage).width(800).url()}
                      alt={post.title}
                      loading="lazy"
                      class="card-img"
                    />
                  </picture>
                </a>
                {post.tags && post.tags.length > 0 && (
                  <span class="card-tag">{post.tags[0]}</span>
                )}
              </div>

              <div class="card-body">
                <div class="card-meta">
                  <time datetime={post.publishedAt}>
                    {post.publishedAt ? new Date(post.publishedAt).toLocaleDateString('en-US', {
                      year: 'numeric',
                      month: 'short',
                      day: 'numeric'
                    }) : 'May 2026'}
                  </time>
                  {post.readTime && (
                    <>
                      <span class="meta-dot">·</span>
                      <span>{post.readTime} min read</span>
                    </>
                  )}
                </div>

                <h2 class="card-title">
                  <a href={`/insights/${post.slug}`}>{post.title}</a>
                </h2>

                <p class="card-excerpt">{post.excerpt}</p>

                <div class="card-footer">
                  <a href={`/insights/${post.slug}`} class="read-more">
                    Read Article
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                      <line x1="5" y1="12" x2="19" y2="12"/>
                      <polyline points="12 5 19 12 12 19"/>
                    </svg>
                  </a>
                </div>
              </div>
            </article>
          ))}
        </section>

        <!-- Pagination Component -->
        {totalPages > 1 && (
          <nav class="pagination" aria-label="Pagination Navigation">
            {currentPage > 1 ? (
              <a href={getPageHref(currentPage - 1)} class="page-btn page-arrow" aria-label="Go to previous page">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <polyline points="15 18 9 12 15 6" />
                </svg>
                Prev
              </a>
            ) : (
              <span class="page-btn page-btn--disabled page-arrow">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <polyline points="15 18 9 12 15 6" />
                </svg>
                Prev
              </span>
            )}

            <div class="page-numbers">
              {Array.from({ length: totalPages }).map((_, idx) => {
                const pageNum = idx + 1;
                const isCurrent = pageNum === currentPage;
                return isCurrent ? (
                  <span class="page-btn page-btn--active" aria-current="page">
                    {pageNum}
                  </span>
                ) : (
                  <a href={getPageHref(pageNum)} class="page-btn" aria-label={`Go to page ${pageNum}`}>
                    {pageNum}
                  </a>
                );
              })}
            </div>

            {currentPage < totalPages ? (
              <a href={getPageHref(currentPage + 1)} class="page-btn page-arrow" aria-label="Go to next page">
                Next
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <polyline points="9 18 15 12 9 6" />
                </svg>
              </a>
            ) : (
              <span class="page-btn page-btn--disabled page-arrow">
                Next
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <polyline points="9 18 15 12 9 6" />
                </svg>
              </span>
            )}
          </nav>
        )}
      ) : (
        <div class="no-posts glass">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/>
            <polyline points="14 2 14 8 20 8"/>
            <line x1="16" y1="13" x2="8" y2="13"/>
            <line x1="16" y1="17" x2="8" y2="17"/>
            <line x1="10" y1="9" x2="8" y2="9"/>
          </svg>
          <h3>No articles found</h3>
          <p>We haven't published any insights in this category yet. Please check back soon or browse our other research articles.</p>
          <a href="/insights" class="btn btn--secondary">View All Insights</a>
        </div>
      )}
    </div>
  </main>
</BaseLayout>

<style>
  .insights-page {
    padding-bottom: var(--space-4xl);
  }

  /* ── Banner ── */
  .page-banner {
    position: relative;
    padding-block: 8rem 4rem;
    overflow: hidden;
    background: linear-gradient(135deg, #030201 0%, #0c0804 50%, #060503 100%);
    border-bottom: 1px solid var(--color-border);
  }

  .banner-gradient {
    position: absolute;
    inset: 0;
    background: radial-gradient(circle 35% 50% at 75% 20%, rgba(212, 166, 84, 0.08) 0%, transparent 100%);
  }

  .banner-title {
    font-size: clamp(2.25rem, 5vw, 3.5rem);
    font-weight: 700;
    margin-top: 0.5rem;
    color: var(--color-text);
  }

  .banner-desc {
    max-width: 600px;
    margin-top: 1rem;
    color: var(--color-text-secondary);
    font-size: 1.0625rem;
  }

  /* ── Filter Tabs ── */
  .filter-container {
    margin-top: -1.75rem;
    position: relative;
    z-index: var(--z-float);
    display: flex;
    justify-content: center;
  }

  .category-tabs {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    justify-content: center;
    background: rgba(8, 13, 8, 0.6);
    border: 1px solid var(--color-border);
    padding: 0.375rem;
    border-radius: var(--radius-lg);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    max-width: 90%;
    box-shadow: var(--shadow-lg);
  }

  .category-tab {
    padding: 0.5rem 1rem;
    border-radius: var(--radius-md);
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    text-decoration: none;
    transition: all var(--transition-fast);
    font-weight: 500;
  }

  .category-tab:hover {
    color: var(--color-text);
    background: var(--color-surface);
  }

  .category-tab--active {
    background: var(--color-primary) !important;
    color: var(--color-surface-bg) !important;
  }

  /* ── Empty State ── */
  .no-posts {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 5rem 2rem;
    border-radius: var(--radius-lg);
    border: 1px solid rgba(212,166,84,0.15) !important;
    max-width: 600px;
    margin: 2rem auto 0;
    width: 100%;
  }

  .no-posts svg {
    color: var(--color-text-muted);
    margin-bottom: 1.5rem;
  }

  .no-posts h3 {
    font-size: 1.625rem;
    font-weight: 600;
    margin-bottom: 0.75rem;
    color: var(--color-text);
  }

  .no-posts p {
    color: var(--color-text-secondary);
    margin-bottom: 2rem;
    line-height: 1.6;
  }

  /* ── Grid ── */
  .insights-container {
    margin-top: 3rem;
    position: relative;
  }

  .insights-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }

  @media (max-width: 1024px) {
    .insights-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 768px) {
    .insights-grid { grid-template-columns: 1fr; }
  }

  /* ── Card ── */
  .blog-card {
    display: flex;
    flex-direction: column;
    height: 100%;
    overflow: hidden;
    transition: transform var(--transition-base), border-color var(--transition-base), box-shadow var(--transition-base);
    border-color: rgba(212,166,84,0.1) !important;
  }

  .blog-card:hover {
    transform: translateY(-5px);
    border-color: var(--color-border-strong) !important;
    box-shadow: var(--shadow-glow-gold);
  }

  .card-image-box {
    position: relative;
    height: 200px;
    background: var(--color-surface-2);
    overflow: hidden;
  }

  .card-image-link {
    display: block;
    width: 100%;
    height: 100%;
  }

  .card-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--transition-slow);
  }

  .blog-card:hover .card-img {
    transform: scale(1.04);
  }

  .card-tag {
    position: absolute;
    top: 0.75rem;
    left: 0.75rem;
    background: var(--color-accent);
    color: #fff;
    font-size: 0.75rem;
    font-weight: 500;
    padding: 0.15rem 0.55rem;
    border-radius: var(--radius-sm);
  }

  .card-body {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    flex-grow: 1;
  }

  .card-meta {
    display: flex;
    align-items: center;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-text-muted);
    margin-bottom: 0.5rem;
  }

  .meta-dot {
    margin-inline: 0.35rem;
  }

  .card-title {
    font-size: 1.375rem;
    font-weight: 600;
    line-height: 1.25;
    margin-bottom: 0.75rem;
  }

  .card-title a {
    color: var(--color-text);
  }

  .card-title a:hover {
    color: var(--color-primary-light);
  }

  .card-excerpt {
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin-bottom: 1.5rem;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card-footer {
    margin-top: auto;
  }

  .read-more {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-primary-light);
    transition: color var(--transition-fast);
  }

  .read-more:hover {
    color: var(--color-accent-light);
  }

  .read-more svg {
    transition: transform var(--transition-fast);
  }

  .read-more:hover svg {
    transform: translateX(3px);
  }

  /* ── Pagination ── */
  .pagination {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 1.5rem;
    margin-top: 4rem;
    border-top: 1px solid var(--color-border);
    padding-top: 2.5rem;
  }

  .page-numbers {
    display: flex;
    gap: 0.5rem;
    align-items: center;
  }

  .page-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: 2.5rem;
    min-width: 2.5rem;
    padding-inline: 0.75rem;
    border-radius: var(--radius-md);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    color: var(--color-text-secondary);
    font-size: 0.875rem;
    font-weight: 500;
    transition: all var(--transition-base);
    text-decoration: none;
    cursor: pointer;
  }

  .page-btn:hover:not(.page-btn--disabled):not(.page-btn--active) {
    color: var(--color-primary-light);
    border-color: var(--color-primary-light);
    background: rgba(212, 166, 84, 0.05);
  }

  .page-btn--active {
    background: var(--color-primary);
    color: var(--color-bg);
    border-color: var(--color-primary);
    cursor: default;
  }

  .page-btn--disabled {
    opacity: 0.4;
    cursor: not-allowed;
  }

  .page-arrow {
    gap: 0.25rem;
    padding-inline: 1rem;
  }
</style>
