---
// src/pages/ru/formulator.astro — Russian Formulation Console page
export const prerender = true;
import BaseLayout from '../../layouts/BaseLayout.astro';
import FormulatorConsole from '../../components/calculators/FormulatorConsole.vue';
import { useTranslations } from '../../i18n/utils';
const lang = 'ru';
const t = useTranslations(lang);
---
<BaseLayout lang={lang} title="Консоль научных рецептур | GINKVORA" description="Профессиональные инструменты для расчёта молярности, разбавлений и рецептур. Разработаны для исследователей и специалистов R&D.">
  <main class="formulator-page bg-noise">
    <header class="page-banner">
      <div class="banner-gradient"></div>
      <div class="container banner-content">
        <span class="section-label">{t('formulator.label')}</span>
        <h1 class="banner-title">{t('formulator.title')}</h1>
        <p class="banner-desc">Профессиональные расчётные инструменты для специалистов R&D и исследователей в области формуляций.</p>
      </div>
    </header>
    <div class="container formulator-layout">
      <FormulatorConsole client:only="vue" />
    </div>
  </main>
</BaseLayout>
<style>
  .formulator-page { padding-block: 0 var(--space-4xl); }
  .page-banner { position: relative; padding-block: 8rem 4rem; background: linear-gradient(135deg, #030201 0%, #0e1007 60%, #0a0703 100%); overflow: hidden; margin-bottom: var(--space-2xl); }
  .banner-gradient { position: absolute; inset: 0; background: radial-gradient(ellipse 60% 80% at 50% 50%, rgba(212,166,84,0.07) 0%, transparent 70%); }
  .banner-content { position: relative; z-index: 1; text-align: center; max-width: 700px; margin-inline: auto; }
  .banner-title { font-size: clamp(2rem, 4.5vw, 3.5rem); font-weight: 700; line-height: 1.15; margin-bottom: 1rem; }
  .banner-desc { font-size: 1.0625rem; color: var(--color-text-secondary); line-height: 1.75; }
  .formulator-layout { padding-bottom: var(--space-2xl); }
</style>
