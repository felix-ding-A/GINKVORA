---
// CertificationsMarquee.astro — Scrolling certifications & partner logos strip
---

<section class="marquee-section" aria-label="Certifications">
  <div class="marquee-wrapper">
    <div class="marquee-track" aria-hidden="true">
      <!-- Duplicated for seamless loop -->
      {[...Array(2)].map(() => (
        <div class="marquee-items">
          <div class="cert-item">
            <div class="cert-icon cert-icon--shield">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
              </svg>
            </div>
            <span>ISO 9001:2015</span>
          </div>
          <div class="cert-separator" aria-hidden="true">·</div>

          <div class="cert-item">
            <div class="cert-icon cert-icon--check">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0 1 12 2.944a11.955 11.955 0 0 1-8.618 3.04A12.02 12.02 0 0 0 3 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
              </svg>
            </div>
            <span>GMP Certified</span>
          </div>
          <div class="cert-separator" aria-hidden="true">·</div>

          <div class="cert-item">
            <div class="cert-icon cert-icon--leaf">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10z"/>
                <path d="M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12"/>
              </svg>
            </div>
            <span>FSSC 22000</span>
          </div>
          <div class="cert-separator" aria-hidden="true">·</div>

          <div class="cert-item">
            <div class="cert-icon cert-icon--star">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
              </svg>
            </div>
            <span>Kosher Certified</span>
          </div>
          <div class="cert-separator" aria-hidden="true">·</div>

          <div class="cert-item">
            <div class="cert-icon cert-icon--moon">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
              </svg>
            </div>
            <span>Halal Certified</span>
          </div>
          <div class="cert-separator" aria-hidden="true">·</div>

          <div class="cert-item">
            <div class="cert-icon cert-icon--lab">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M8 3H6a2 2 0 0 0-2 2v16c0 1.1.9 2 2 2h12a2 2 0 0 0 2-2V5a2 2 0 0 0-2-2h-2"/>
                <rect x="8" y="1" width="8" height="4" rx="1"/>
                <path d="M9 12h6M9 16h4"/>
              </svg>
            </div>
            <span>COA Available</span>
          </div>
          <div class="cert-separator" aria-hidden="true">·</div>

          <div class="cert-item">
            <div class="cert-icon cert-icon--globe">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="12" r="10"/>
                <path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
              </svg>
            </div>
            <span>Global Shipping</span>
          </div>
          <div class="cert-separator" aria-hidden="true">·</div>

          <div class="cert-item">
            <div class="cert-icon cert-icon--test">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M14.5 2v17.5c0 1.4-1.1 2.5-2.5 2.5h0c-1.4 0-2.5-1.1-2.5-2.5V2"/>
                <path d="M8.5 2h7"/>
                <path d="M14.5 16h-5"/>
              </svg>
            </div>
            <span>Third-Party Tested</span>
          </div>
          <div class="cert-separator" aria-hidden="true">·</div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .marquee-section {
    background: var(--color-surface);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
    padding: 1rem 0;
    overflow: hidden;
  }

  .marquee-wrapper {
    position: relative;
  }

  /* Fade edges */
  .marquee-wrapper::before,
  .marquee-wrapper::after {
    content: '';
    position: absolute;
    top: 0;
    bottom: 0;
    width: 120px;
    z-index: 2;
    pointer-events: none;
  }

  .marquee-wrapper::before {
    left: 0;
    background: linear-gradient(to right, var(--color-surface), transparent);
  }

  .marquee-wrapper::after {
    right: 0;
    background: linear-gradient(to left, var(--color-surface), transparent);
  }

  .marquee-track {
    display: flex;
    animation: marquee 30s linear infinite;
    width: max-content;
  }

  .marquee-track:hover {
    animation-play-state: paused;
  }

  .marquee-items {
    display: flex;
    align-items: center;
    gap: 0;
  }

  .cert-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1.25rem;
    color: var(--color-text-muted);
    font-size: 0.875rem;
    font-weight: 500;
    white-space: nowrap;
    letter-spacing: 0.02em;
    transition: color var(--transition-fast);
  }

  .cert-item:hover {
    color: var(--color-text-secondary);
  }

  .cert-icon {
    width: 28px;
    height: 28px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: var(--radius-sm);
    flex-shrink: 0;
  }

  .cert-icon--shield  { color: var(--color-primary); background: rgba(212, 166, 84, 0.1); }
  .cert-icon--check   { color: var(--color-primary-light); background: rgba(240, 200, 120, 0.1); }
  .cert-icon--leaf    { color: var(--color-accent); background: rgba(224, 120, 48, 0.1); }
  .cert-icon--star    { color: var(--color-primary-light); background: rgba(212, 166, 84, 0.1); }
  .cert-icon--moon    { color: var(--color-accent-light); background: rgba(240, 144, 80, 0.1); }
  .cert-icon--lab     { color: var(--color-primary); background: rgba(212, 166, 84, 0.1); }
  .cert-icon--globe   { color: var(--color-accent); background: rgba(224, 120, 48, 0.1); }
  .cert-icon--test    { color: var(--color-primary-light); background: rgba(240, 200, 120, 0.1); }

  .cert-separator {
    color: var(--color-border-strong);
    font-size: 1.25rem;
    padding: 0 0.25rem;
    select-events: none;
  }

  @media (prefers-reduced-motion: reduce) {
    .marquee-track { animation: none; }
  }
</style>
