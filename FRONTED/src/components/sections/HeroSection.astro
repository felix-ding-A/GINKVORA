---
// HeroSection.astro — Full-screen hero with gold/black/orange theme
---

<section class="hero" id="hero" aria-label="Hero">
  <!-- Animated background -->
  <div class="hero-bg" aria-hidden="true">
    <div class="hero-gradient"></div>
    <canvas id="particle-canvas" class="particle-canvas"></canvas>
    <div class="orb orb--1"></div>
    <div class="orb orb--2"></div>
    <div class="orb orb--3"></div>
    <!-- Diagonal light streak -->
    <div class="light-streak" aria-hidden="true"></div>
  </div>

  <div class="container hero-content">
    <!-- Left copy -->
    <div class="hero-left">
      <div class="hero-label reveal">
        <span class="badge badge--gold">
          <svg width="8" height="8" viewBox="0 0 8 8" fill="currentColor" aria-hidden="true">
            <circle cx="4" cy="4" r="4"/>
          </svg>
          B2B Plant Extract Supplier
        </span>
      </div>

      <h1 class="hero-title reveal reveal-delay-1">
        Pure Nature,<br/>
        <span class="gradient-text--gold">Proven Science</span>
      </h1>

      <p class="hero-sub reveal reveal-delay-2">
        Premium botanical extracts for global nutraceutical, cosmetic, and pet health industries.
        500+ high-purity ingredients — from&nbsp;<strong>PQQ</strong> and&nbsp;<strong>NMN</strong>
        to&nbsp;<strong>EGCG</strong> and&nbsp;<strong>Glabridin</strong>.
      </p>

      <div class="hero-ctas reveal reveal-delay-3">
        <a href="/products" class="btn btn--gold btn--lg" id="hero-explore-btn">
          Explore Products
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
        <a href="/contact" class="btn btn--primary btn--lg" id="hero-quote-btn">
          Request a Sample
        </a>
      </div>

      <!-- Trust indicators -->
      <div class="hero-trust reveal reveal-delay-4">
        <div class="trust-item">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
          </svg>
          GMP Certified
        </div>
        <span class="trust-divider" aria-hidden="true"></span>
        <div class="trust-item">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <circle cx="12" cy="12" r="10"/>
            <path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
          </svg>
          50+ Countries Served
        </div>
        <span class="trust-divider" aria-hidden="true"></span>
        <div class="trust-item">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M9 12l2 2 4-4"/>
            <circle cx="12" cy="12" r="10"/>
          </svg>
          ISO 9001:2015
        </div>
      </div>
    </div>

    <!-- Right: ingredient showcase -->
    <div class="hero-right reveal reveal-delay-2">
      <div class="ingredient-card-stack">
        <!-- Main card -->
        <div class="ingredient-showcase glass animate-float">
          <div class="showcase-header">
            <div class="showcase-dot"></div>
            <span class="showcase-label">Featured Ingredient</span>
          </div>
          <div class="showcase-body">
            <div class="showcase-molecule" aria-hidden="true">
              <svg width="110" height="110" viewBox="0 0 120 120" fill="none">
                <circle cx="60" cy="60" r="20" fill="rgba(212,166,84,0.1)" stroke="rgba(212,166,84,0.35)" stroke-width="1.5"/>
                <circle cx="60" cy="20" r="10" fill="rgba(224,120,48,0.15)" stroke="rgba(224,120,48,0.4)" stroke-width="1.5"/>
                <circle cx="95" cy="80" r="10" fill="rgba(212,166,84,0.15)" stroke="rgba(212,166,84,0.4)" stroke-width="1.5"/>
                <circle cx="25" cy="80" r="10" fill="rgba(224,120,48,0.12)" stroke="rgba(224,120,48,0.35)" stroke-width="1.5"/>
                <line x1="60" y1="40" x2="60" y2="30" stroke="rgba(212,166,84,0.4)" stroke-width="1.5"/>
                <line x1="75" y1="66" x2="87" y2="73" stroke="rgba(224,120,48,0.4)" stroke-width="1.5"/>
                <line x1="45" y1="66" x2="33" y2="73" stroke="rgba(212,166,84,0.4)" stroke-width="1.5"/>
                <circle cx="60" cy="60" r="5" fill="#d4a654"/>
              </svg>
            </div>
            <h3 class="showcase-name">PQQ</h3>
            <p class="showcase-full-name">Pyrroloquinoline Quinone</p>
            <div class="showcase-purity">
              <span class="purity-label">Purity</span>
              <span class="purity-value">≥ 99%</span>
            </div>
            <div class="showcase-tags">
              <span class="showcase-tag">Mitochondria</span>
              <span class="showcase-tag">Antioxidant</span>
              <span class="showcase-tag">Cognitive</span>
            </div>
          </div>
        </div>

        <!-- Mini floating cards -->
        <div class="mini-card glass" style="--float-d:0s; top:8%; right:-4%;">
          <span class="mini-card-name">NMN</span>
          <span class="mini-card-purity">≥ 99%</span>
        </div>
        <div class="mini-card glass" style="--float-d:1.5s; bottom:18%; left:-6%;">
          <span class="mini-card-name">EGCG</span>
          <span class="mini-card-purity">≥ 98%</span>
        </div>
        <div class="mini-card glass" style="--float-d:3s; bottom:4%; right:2%;">
          <span class="mini-card-name">Luteolin</span>
          <span class="mini-card-purity">≥ 98%</span>
        </div>
      </div>
    </div>
  </div>

  <!-- Wave divider -->
  <div class="hero-wave" aria-hidden="true">
    <svg viewBox="0 0 1440 100" fill="none" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
      <path d="M0 60 C240 100 480 20 720 60 C960 100 1200 20 1440 60 L1440 100 L0 100 Z" fill="var(--color-bg)"/>
    </svg>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    overflow: hidden;
    padding-top: 5rem;
  }

  /* ── Background ── */
  .hero-bg {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, #030201 0%, #0a0703 35%, #120a04 65%, #060503 100%);
  }

  .hero-gradient {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 55% 60% at 15% 50%, rgba(212,166,84,0.09) 0%, transparent 70%),
      radial-gradient(ellipse 45% 50% at 85% 25%, rgba(224,120,48,0.08) 0%, transparent 70%),
      radial-gradient(ellipse 35% 40% at 70% 80%, rgba(212,166,84,0.05) 0%, transparent 70%);
  }

  .particle-canvas {
    position: absolute; inset: 0;
    width: 100%; height: 100%;
    opacity: 0.7;
  }

  /* Glowing orbs */
  .orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(90px);
    pointer-events: none;
  }
  .orb--1 {
    width: 450px; height: 450px;
    background: rgba(212,166,84,0.07);
    top: -15%; left: -8%;
    animation: float 9s ease-in-out infinite;
  }
  .orb--2 {
    width: 320px; height: 320px;
    background: rgba(224,120,48,0.07);
    bottom: 5%; right: 5%;
    animation: float 11s ease-in-out infinite 2s;
  }
  .orb--3 {
    width: 220px; height: 220px;
    background: rgba(212,166,84,0.06);
    top: 35%; right: 22%;
    animation: float 13s ease-in-out infinite 4s;
  }

  /* Diagonal light streak */
  .light-streak {
    position: absolute;
    top: -10%;
    left: 30%;
    width: 1px;
    height: 130%;
    background: linear-gradient(to bottom, transparent, rgba(212,166,84,0.12) 40%, rgba(224,120,48,0.08) 60%, transparent);
    transform: rotate(15deg);
    pointer-events: none;
  }

  /* ── Content ── */
  .hero-content {
    position: relative;
    z-index: var(--z-base);
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
    padding-block: 6rem 8rem;
  }

  .hero-left {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .hero-label { display: flex; }

  .hero-title {
    font-size: clamp(2.75rem, 5.5vw, 5rem);
    font-weight: 700;
    line-height: 1.08;
    letter-spacing: -0.02em;
    color: var(--color-text);
  }

  .hero-sub {
    font-size: clamp(1rem, 1.5vw, 1.175rem);
    line-height: 1.75;
    color: var(--color-text-secondary);
    max-width: 480px;
  }

  .hero-sub strong {
    color: var(--color-primary-light);
    font-weight: 500;
  }

  .hero-ctas { display: flex; gap: 1rem; flex-wrap: wrap; }

  /* Trust */
  .hero-trust {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
    padding-top: 0.5rem;
  }

  .trust-item {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.875rem;
    color: var(--color-text-muted);
    stroke: var(--color-primary);
  }
  .trust-item svg { color: var(--color-primary); }

  .trust-divider {
    width: 1px;
    height: 14px;
    background: var(--color-border-strong);
  }

  /* ── Ingredient showcase ── */
  .hero-right {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .ingredient-card-stack {
    position: relative;
    width: 320px;
    height: 390px;
  }

  .ingredient-showcase {
    position: absolute;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    width: 285px;
    padding: 1.5rem;
    animation: float 5s ease-in-out infinite;
    border-color: rgba(212,166,84,0.2) !important;
  }

  .showcase-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }

  .showcase-dot {
    width: 8px; height: 8px;
    background: var(--color-primary);
    border-radius: 50%;
    box-shadow: 0 0 10px var(--color-primary);
    animation: pulse-glow-gold 2s ease-in-out infinite;
  }

  .showcase-label {
    font-size: 0.7rem;
    font-weight: 600;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .showcase-body { text-align: center; }

  .showcase-molecule {
    display: flex;
    justify-content: center;
    margin-bottom: 1rem;
    opacity: 0.85;
  }

  .showcase-name {
    font-family: var(--font-display);
    font-size: 2.25rem;
    font-weight: 700;
    background: linear-gradient(135deg, #f0c878, #d4a654);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    margin-bottom: 0.25rem;
  }

  .showcase-full-name {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    font-style: italic;
    font-family: var(--font-display);
    margin-bottom: 0.875rem;
  }

  .showcase-purity {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    margin-bottom: 0.875rem;
  }

  .purity-label {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .purity-value {
    font-family: var(--font-mono);
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-primary-light);
    background: rgba(212,166,84,0.15);
    padding: 0.15rem 0.55rem;
    border-radius: var(--radius-full);
    border: 1px solid rgba(212,166,84,0.3);
  }

  .showcase-tags {
    display: flex;
    gap: 0.375rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .showcase-tag {
    font-size: 0.68rem;
    font-weight: 500;
    color: var(--color-text-muted);
    background: var(--color-surface-2);
    padding: 0.2rem 0.5rem;
    border-radius: var(--radius-full);
    border: 1px solid var(--color-border);
  }

  /* Mini cards */
  .mini-card {
    position: absolute;
    padding: 0.625rem 0.875rem;
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    border-color: rgba(212,166,84,0.15) !important;
    animation: float var(--float-d, 0s) ease-in-out infinite;
    animation-delay: var(--float-d, 0s);
    animation-duration: 5s;
  }

  .mini-card-name {
    font-family: var(--font-display);
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--color-text);
  }

  .mini-card-purity {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--color-primary);
  }

  /* Wave */
  .hero-wave {
    position: absolute;
    bottom: -1px; left: 0; right: 0;
    overflow: hidden;
    line-height: 0;
  }
  .hero-wave svg {
    display: block;
    width: 100%; height: 100px;
  }

  /* Responsive */
  @media (max-width: 1200px) {
    .hero-content { gap: 2rem; }
    .mini-card[style*="left:-6%"] { left: -2%; }
    .mini-card[style*="right:-4%"] { right: -1%; }
  }

  @media (max-width: 1024px) {
    .hero-content {
      grid-template-columns: 1fr;
      text-align: center;
      padding-block: 5rem 6rem;
      gap: 3rem;
    }
    .hero-sub  { max-width: 100%; margin-inline: auto; }
    .hero-ctas { justify-content: center; }
    .hero-trust { justify-content: center; }
    .hero-label { justify-content: center; }
    .hero-right {
      width: 100%;
      margin-top: 1rem;
    }
    .ingredient-card-stack {
      width: 100%;
      max-width: 285px;
      height: auto;
      margin: 0 auto;
    }
    .ingredient-showcase {
      position: relative;
      top: auto;
      left: auto;
      transform: none;
      width: 100%;
      margin: 0 auto;
      animation: float 5s ease-in-out infinite;
    }
    .mini-card { display: none; } /* Hide mini floating cards on tablet and mobile to prevent overlapping */
  }

  @media (max-width: 480px) {
    .hero-ctas { flex-direction: column; align-items: stretch; }
    .hero-ctas .btn { justify-content: center; }
  }
</style>

<script>
  // Particle canvas — gold/orange colors
  const canvas = document.getElementById('particle-canvas') as HTMLCanvasElement;
  if (canvas) {
    const ctx = canvas.getContext('2d')!;
    let particles: Array<{x:number;y:number;vx:number;vy:number;size:number;opacity:number;color:string}> = [];
    let animFrame: number;

    const colors = [
      'rgba(212, 166, 84, ',
      'rgba(240, 200, 120, ',
      'rgba(224, 120, 48, ',
      'rgba(160, 120, 48, ',
    ];

    function resize() {
      canvas.width = canvas.offsetWidth;
      canvas.height = canvas.offsetHeight;
    }

    function createParticles() {
      particles = [];
      const count = Math.floor((canvas.width * canvas.height) / 12000);
      for (let i = 0; i < count; i++) {
        particles.push({
          x: Math.random() * canvas.width,
          y: Math.random() * canvas.height,
          vx: (Math.random() - 0.5) * 0.28,
          vy: (Math.random() - 0.5) * 0.28,
          size: Math.random() * 2 + 0.5,
          opacity: Math.random() * 0.45 + 0.1,
          color: colors[Math.floor(Math.random() * colors.length)],
        });
      }
    }

    function draw() {
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      particles.forEach((p) => {
        p.x += p.vx; p.y += p.vy;
        if (p.x < 0) p.x = canvas.width;
        if (p.x > canvas.width) p.x = 0;
        if (p.y < 0) p.y = canvas.height;
        if (p.y > canvas.height) p.y = 0;
        ctx.beginPath();
        ctx.arc(p.x, p.y, p.size, 0, Math.PI * 2);
        ctx.fillStyle = `${p.color}${p.opacity})`;
        ctx.fill();
      });

      // Connect nearby particles
      for (let i = 0; i < particles.length; i++) {
        for (let j = i + 1; j < particles.length; j++) {
          const dx = particles[i].x - particles[j].x;
          const dy = particles[i].y - particles[j].y;
          const dist = Math.sqrt(dx*dx + dy*dy);
          if (dist < 90) {
            ctx.beginPath();
            ctx.moveTo(particles[i].x, particles[i].y);
            ctx.lineTo(particles[j].x, particles[j].y);
            ctx.strokeStyle = `rgba(212,166,84,${(1 - dist/90) * 0.07})`;
            ctx.stroke();
          }
        }
      }
      animFrame = requestAnimationFrame(draw);
    }

    resize(); createParticles(); draw();
    window.addEventListener('resize', () => { resize(); createParticles(); }, { passive: true });
    document.addEventListener('astro:before-swap', () => cancelAnimationFrame(animFrame));
  }
</script>
