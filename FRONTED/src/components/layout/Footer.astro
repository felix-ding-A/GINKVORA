---
// Footer.astro — Professional B2B footer
import { useTranslations, getLocalePath } from '../../i18n/utils';
import type { Lang } from '../../i18n/utils';

interface Props {
  lang?: string;
}
const { lang = 'en' } = Astro.props;
const typedLang = lang as Lang;
const t = useTranslations(typedLang);
const lp = (path: string) => getLocalePath(typedLang, path);

const currentYear = new Date().getFullYear();

const productLinks = [
  { href: `${lp('/products')}?category=health-supplements`, label: t('footer.link_supplements') },
  { href: `${lp('/products')}?category=cosmetic-actives`,   label: t('footer.link_cosmetics') },
  { href: `${lp('/products')}?category=pet-health`,         label: t('footer.link_pet') },
  { href: lp('/contact'),                                   label: t('footer.link_custom') },
];

const popularIngredients = [
  { href: lp('/products/pqq-disodium-salt'),              label: 'PQQ' },
  { href: lp('/products/nmn-beta-nicotinamide-mononucleotide'), label: 'NMN' },
  { href: lp('/products/egcg-98'),                        label: 'EGCG' },
  { href: lp('/products/glabridin-40'),                   label: 'Glabridin' },
  { href: lp('/products/luteolin-98'),                    label: 'Luteolin' },
  { href: lp('/products/flavone-99'),                     label: 'Flavone' },
];

const companyLinks = [
  { href: lp('/about'),     label: t('footer.link_about') },
  { href: lp('/quality'),   label: t('footer.link_quality') },
  { href: lp('/insights'),  label: t('footer.link_insights') },
  { href: lp('/contact'),   label: t('footer.link_contact') },
];
---

<footer class="footer">
  <!-- Wave top -->
  <div class="footer-wave" aria-hidden="true">
    <svg viewBox="0 0 1440 80" fill="none" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
      <path d="M0 40 C360 80 720 0 1080 40 C1260 60 1380 30 1440 20 L1440 80 L0 80 Z" fill="#0e1a0e"/>
    </svg>
  </div>

  <div class="footer-body">
    <div class="container">
      <div class="footer-grid">
        <!-- Brand column -->
        <div class="footer-brand">
          <a href="/" class="footer-logo" aria-label="GINKVORA Home">
            <svg width="28" height="28" viewBox="0 0 100 120" fill="none" aria-hidden="true" xmlns="http://www.w3.org/2000/svg">
              <!-- Background Soft Droplet Base Glow -->
              <path id="svg-droplet-glow-footer" d="M50 12 C68 33 85 45 85 68 C85 85 68 85 50 85 C32 85 15 85 15 68 C15 45 32 33 50 12 Z" fill="url(#grad-accent-glow-footer)" opacity="0.12" style="opacity: 0;"></path>
              
              <!-- Droplet Outer Ring Outline -->
              <path id="svg-droplet-contour-footer" d="M50 15 C66 36 82 46 82 68 C82 83 68 83 50 83 C32 83 18 83 18 68 C18 46 34 36 50 15 Z" stroke="url(#grad-contour-stroke-footer)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="display: block;"></path>
              
              <!-- Ginkgo Leaf - Left Petal -->
              <path id="svg-leaf-left-footer" d="M50 78 C50 78 51 55 35 44 C26 38 29 48 38 56 C45 62 47 70 50 78 Z" fill="url(#grad-leaf-main-footer)" opacity="0.95" stroke="none" stroke-width="1.8"></path>
              
              <!-- Ginkgo Leaf - Right Petal -->
              <path id="svg-leaf-right-footer" d="M50 78 C50 78 49 55 65 44 C74 38 71 48 62 56 C55 62 53 70 50 78 Z" fill="url(#grad-leaf-main-footer)" opacity="0.95" stroke="none" stroke-width="1.8"></path>
              
              <!-- Central Stem and Branching veins -->
              <path id="svg-leaf-stem-footer" d="M50 78 V38" stroke="url(#grad-contour-stroke-footer)" stroke-width="2.2" stroke-linecap="round"></path>
              
              <!-- Pure Dewdrop / Morning Sun Accent -->
              <circle id="svg-dewdrop-footer" cx="50" cy="30" r="4" fill="url(#grad-dewdrop-color-footer)"></circle>
              <defs>
                <!-- Glow Gradient -->
                <linearGradient id="grad-accent-glow-footer" x1="50" y1="12" x2="50" y2="85" gradientUnits="userSpaceOnUse">
                  <stop offset="0%" stop-color="#34d399"></stop>
                  <stop offset="100%" stop-color="#059669"></stop>
                </linearGradient>
                
                <!-- Contour Stroke Gradient -->
                <linearGradient id="grad-contour-stroke-footer" x1="50" y1="15" x2="50" y2="83" gradientUnits="userSpaceOnUse">
                  <stop offset="0%" stop-color="#fde68a"></stop>
                  <stop offset="100%" stop-color="#9a3412"></stop>
                </linearGradient>
                
                <!-- Leaf Main Color Gradient -->
                <linearGradient id="grad-leaf-main-footer" x1="50" y1="38" x2="50" y2="78" gradientUnits="userSpaceOnUse">
                  <stop id="grad-leaf-stop-1-footer" offset="0%" stop-color="#fbbf24"></stop>
                  <stop id="grad-leaf-stop-2-footer" offset="100%" stop-color="#b45309"></stop>
                </linearGradient>

                <!-- Dewdrop Highlight Gradient -->
                <linearGradient id="grad-dewdrop-color-footer" x1="50" y1="26" x2="50" y2="34" gradientUnits="userSpaceOnUse">
                  <stop id="grad-dew-stop-1-footer" offset="0%" stop-color="#f59e0b"></stop>
                  <stop id="grad-dew-stop-2-footer" offset="100%" stop-color="#fef3c7"></stop>
                </linearGradient>
              </defs>
            </svg>
            <span class="footer-logo-text">GINKVORA</span>
          </a>
          <p class="footer-tagline">
            {t('footer.tagline')}<br/>
            {t('footer.tagline_sub')}
          </p>
          <!-- Certifications mini badges -->
          <div class="footer-certs" aria-label="Certifications">
            <span class="cert-badge">ISO</span>
            <span class="cert-badge">GMP</span>
            <span class="cert-badge">FSSC</span>
            <span class="cert-badge">Kosher</span>
            <span class="cert-badge">Halal</span>
          </div>
        </div>

        <!-- Products -->
        <div class="footer-col">
          <h3 class="footer-col-title">{t('footer.col_products')}</h3>
          <ul class="footer-links" role="list">
            {productLinks.map((link) => (
              <li><a href={link.href} class="footer-link">{link.label}</a></li>
            ))}
          </ul>
        </div>

        <!-- Popular Ingredients -->
        <div class="footer-col">
          <h3 class="footer-col-title">{t('footer.col_ingredients')}</h3>
          <ul class="footer-links" role="list">
            {popularIngredients.map((link) => (
              <li><a href={link.href} class="footer-link">{link.label}</a></li>
            ))}
          </ul>
        </div>

        <!-- Company -->
        <div class="footer-col">
          <h3 class="footer-col-title">{t('footer.col_company')}</h3>
          <ul class="footer-links" role="list">
            {companyLinks.map((link) => (
              <li><a href={link.href} class="footer-link">{link.label}</a></li>
            ))}
          </ul>

          <!-- Contact info -->
          <div class="footer-contact">
            <a href="mailto:inquiry@ginkvora.com" class="footer-contact-item">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <rect width="20" height="16" x="2" y="4" rx="2"/>
                <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
              </svg>
              inquiry@ginkvora.com
            </a>
            <a href={lp('/contact')} class="footer-contact-item">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.28h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.71a16 16 0 0 0 6 6l.91-.91a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 21.73 16c.112.27.18.558.19.85v.07z"/>
              </svg>
              {t('footer.link_rfq')}
            </a>
          </div>
        </div>
      </div>

      <!-- Bottom bar -->
      <div class="footer-bottom">
        <p class="footer-copy">
          &copy; {currentYear} GINKVORA. {t('footer.copyright')}
        </p>
        <div class="footer-legal">
          <a href={lp('/privacy')} class="footer-legal-link">{t('footer.privacy')}</a>
          <a href={lp('/terms')}   class="footer-legal-link">{t('footer.terms')}</a>
          <a href="/sitemap.xml"   class="footer-legal-link">{t('footer.sitemap')}</a>
        </div>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--color-bg-deep);
    margin-top: 0;
  }

  .footer-wave {
    width: 100%;
    overflow: hidden;
    line-height: 0;
    background: var(--color-bg);
  }

  .footer-wave svg {
    display: block;
    width: 100%;
    height: 80px;
  }

  .footer-body {
    padding: 3rem 0 2rem;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1.2fr;
    gap: 3rem;
    margin-bottom: 3rem;
  }

  .footer-logo {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    text-decoration: none;
    margin-bottom: 1rem;
  }

  .footer-logo-text {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    background: linear-gradient(135deg, #f0c878, #d4a654);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .footer-tagline {
    font-size: 0.9rem;
    line-height: 1.7;
    color: var(--color-text-muted);
    margin-bottom: 1.25rem;
  }

  .footer-certs {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
  }

  .cert-badge {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    padding: 0.2rem 0.5rem;
    border-radius: var(--radius-sm);
    border: 1px solid var(--color-border-strong);
    color: var(--color-text-muted);
    font-family: var(--font-mono);
  }

  .footer-col-title {
    font-family: var(--font-body);
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin-bottom: 1rem;
  }

  .footer-links {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .footer-link {
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .footer-link:hover {
    color: var(--color-primary-light);
  }

  .footer-contact {
    margin-top: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  .footer-contact-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .footer-contact-item:hover {
    color: var(--color-primary-light);
  }

  .footer-bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-border);
  }

  .footer-copy {
    font-size: 0.875rem;
    color: var(--color-text-muted);
  }

  .footer-legal {
    display: flex;
    gap: 1.5rem;
  }

  .footer-legal-link {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .footer-legal-link:hover { color: var(--color-text-secondary); }

  @media (max-width: 1024px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
      gap: 2rem;
    }

    .footer-brand {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 640px) {
    .footer-grid {
      grid-template-columns: 1fr;
    }

    .footer-bottom {
      flex-direction: column;
      gap: 1rem;
      align-items: flex-start;
    }
  }
</style>
