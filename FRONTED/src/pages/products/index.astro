---
// src/pages/products/index.astro — Products listing page with search and category filters
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getAllProducts, getAllCategories, urlFor } from '../../lib/sanity';

const products = await getAllProducts();
const categories = await getAllCategories();

const siteUrl = 'https://ginkvora.com';

// Breadcrumb structured data
const breadcrumbsSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": siteUrl
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Products",
      "item": `${siteUrl}/products`
    }
  ]
};

// ItemList structured data — enables rich product list results in Google
const itemListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "GINKVORA Plant Extract Product Catalog",
  "description": "Premium B2B botanical extracts and active ingredients — PQQ, NMN, EGCG, Glabridin, and 500+ more.",
  "url": `${siteUrl}/products`,
  "numberOfItems": products.length,
  "itemListElement": products.map((prod, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "url": `${siteUrl}/products/${prod.slug}`,
    "name": prod.name,
  }))
};
---

<BaseLayout
  title="High-Purity Plant Extracts & Active Ingredients | GINKVORA"
  description="Explore our catalog of 500+ premium botanical extracts, active ingredients, cosmetic actives, and custom formulations. ISO & GMP certified."
>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbsSchema)} slot="head" />
  <script type="application/ld+json" set:html={JSON.stringify(itemListSchema)} slot="head" />


  <main class="products-page bg-noise">
    <!-- Header banner -->
    <header class="page-banner" aria-label="Page Header">
      <div class="banner-gradient"></div>
      <div class="container banner-content">
        <span class="section-label">B2B Product Catalog</span>
        <h1 class="banner-title">Pure Bioactive Ingredients</h1>
        <p class="banner-desc">
          Premium raw materials tested under strict USP/EP quality standards for supplement, cosmetic, and functional food manufacturers.
        </p>
      </div>
    </header>

    <div class="container catalog-container">
      <!-- Filter and search bar -->
      <section class="controls-section glass" aria-label="Filters and Search">
        <div class="search-box">
          <svg class="search-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <circle cx="11" cy="11" r="8"/>
            <path d="m21 21-4.3-4.3"/>
          </svg>
          <input
            type="search"
            id="product-search"
            placeholder="Search ingredients by name, CAS number, or application..."
            aria-label="Search ingredients"
          />
        </div>

        <nav class="category-tabs" aria-label="Product categories">
          <button class="category-tab active" data-category="all" id="btn-cat-all">
            All Products
          </button>
          {categories.map((cat) => (
            <button class="category-tab" data-category={cat.slug} id={`btn-cat-${cat.slug}`}>
              <span class="tab-icon">{cat.icon || '🌿'}</span>
              {cat.name}
            </button>
          ))}
        </nav>
      </section>

      <!-- Products Grid -->
      <section class="products-section" aria-label="Product List">
        <div class="products-count" id="products-count-label">
          Showing {products.length} products
        </div>

        <div class="products-grid" id="products-grid">
          {products.map((prod) => (
            <article
              class="product-card glass reveal"
              data-category={prod.category.slug}
              data-name={prod.name.toLowerCase()}
              data-cas={prod.casNumber ? prod.casNumber.toLowerCase() : ''}
              data-desc={prod.shortDescription ? prod.shortDescription.toLowerCase() : ''}
            >
              <div class="card-image-wrapper">
                <picture style="display: contents;">
                  <source srcset={urlFor(prod.heroImage).width(800).format('webp').url()} type="image/webp" />
                  <img
                    src={urlFor(prod.heroImage).width(800).url()}
                    alt={prod.name}
                    loading="lazy"
                    class="card-image"
                  />
                </picture>
                <span class="card-category-badge">{prod.category.name}</span>
              </div>

              <div class="card-content">
                <div class="card-specs">
                  {prod.purity && (
                    <span class="card-purity">{prod.purity}</span>
                  )}
                  {prod.casNumber && (
                    <span class="card-cas">CAS: {prod.casNumber}</span>
                  )}
                </div>

                <h3 class="card-title">
                  <a href={`/products/${prod.slug}`}>{prod.name}</a>
                </h3>

                {prod.botanicalName && (
                  <p class="card-botanical">{prod.botanicalName}</p>
                )}

                <p class="card-desc">{prod.shortDescription}</p>

                <div class="card-footer">
                  <a href={`/products/${prod.slug}`} class="btn btn--secondary btn--sm">
                    Specifications
                  </a>
                  <a href={`/contact?product=${encodeURIComponent(prod.name)}`} class="btn btn--primary btn--sm">
                    Inquire
                  </a>
                </div>
              </div>
            </article>
          ))}
        </div>

        <!-- Empty state -->
        <div class="empty-state" id="empty-state" style="display: none;" role="alert">
          <div class="empty-icon">🔍</div>
          <h3>No products match your search</h3>
          <p>Try checking your spelling, selecting a different category, or contacting us for custom sourcing.</p>
          <button class="btn btn--gold" id="reset-filters">Reset Filters</button>
        </div>
      </section>
    </div>
  </main>
</BaseLayout>

<style>
  .products-page {
    padding-bottom: var(--space-4xl);
  }

  /* ── Banner ── */
  .page-banner {
    position: relative;
    padding-block: 8rem 4rem;
    overflow: hidden;
    background: linear-gradient(135deg, #030201 0%, #0c0804 50%, #060503 100%);
    border-bottom: 1px solid var(--color-border);
  }

  .banner-gradient {
    position: absolute;
    inset: 0;
    background: radial-gradient(circle 35% 50% at 75% 20%, rgba(212, 166, 84, 0.08) 0%, transparent 100%);
  }

  .banner-content {
    position: relative;
    z-index: var(--z-base);
  }

  .banner-title {
    font-size: clamp(2.25rem, 5vw, 3.5rem);
    font-weight: 700;
    margin-top: 0.5rem;
    color: var(--color-text);
  }

  .banner-desc {
    max-width: 600px;
    margin-top: 1rem;
    color: var(--color-text-secondary);
    font-size: 1.0625rem;
  }

  /* ── Controls Section ── */
  .catalog-container {
    margin-top: -2rem;
    position: relative;
    z-index: var(--z-float);
  }

  .controls-section {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    padding: 1.5rem;
    border-radius: var(--radius-lg);
    border-color: rgba(212, 166, 84, 0.18) !important;
  }

  .search-box {
    position: relative;
    width: 100%;
  }

  .search-icon {
    position: absolute;
    left: 1rem;
    top: 50%;
    transform: translateY(-50%);
    color: var(--color-text-muted);
    pointer-events: none;
  }

  .search-box input {
    width: 100%;
    padding: 0.875rem 1rem 0.875rem 3rem;
    background: var(--color-bg-deep);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    color: var(--color-text);
    font-size: 1rem;
    transition: all var(--transition-fast);
  }

  .search-box input:focus {
    outline: none;
    border-color: var(--color-primary);
    box-shadow: 0 0 0 3px rgba(212, 166, 84, 0.15);
  }

  .category-tabs {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    border-top: 1px solid var(--color-border);
    padding-top: 1.25rem;
  }

  .category-tab {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    border-radius: var(--radius-full);
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-text-secondary);
    background: transparent;
    border: 1px solid transparent;
    cursor: pointer;
    transition: all var(--transition-fast);
  }

  .category-tab:hover {
    color: var(--color-primary-light);
    border-color: var(--color-border-strong);
    background: rgba(212, 166, 84, 0.05);
  }

  .category-tab.active {
    color: var(--color-bg);
    background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 100%);
    border-color: var(--color-primary);
    box-shadow: 0 4px 12px rgba(212, 166, 84, 0.2);
  }

  /* ── Products List ── */
  .products-section {
    margin-top: 2.5rem;
  }

  .products-count {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    margin-bottom: 1rem;
    font-family: var(--font-mono);
  }

  .products-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.75rem;
  }

  @media (max-width: 1024px) {
    .products-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 768px) {
    .products-grid { grid-template-columns: 1fr; }
  }

  /* ── Product Card ── */
  .product-card {
    display: flex;
    flex-direction: column;
    height: 100%;
    overflow: hidden;
    transition: transform var(--transition-base), border-color var(--transition-base), box-shadow var(--transition-base);
    border-color: rgba(212, 166, 84, 0.1) !important;
    opacity: 1;
    transform: translateY(0);
  }

  .product-card:hover {
    transform: translateY(-5px);
    border-color: var(--color-border-strong) !important;
    box-shadow: var(--shadow-glow-gold);
  }

  .card-image-wrapper {
    position: relative;
    height: 180px;
    background: var(--color-surface-2);
    overflow: hidden;
  }

  .card-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--transition-slow);
  }

  .product-card:hover .card-image {
    transform: scale(1.05);
  }

  .card-category-badge {
    position: absolute;
    bottom: 0.75rem;
    left: 0.75rem;
    background: rgba(6, 5, 3, 0.8);
    backdrop-filter: blur(8px);
    border: 1px solid var(--color-border);
    padding: 0.2rem 0.6rem;
    border-radius: var(--radius-sm);
    font-size: 0.75rem;
    color: var(--color-primary-light);
  }

  .card-content {
    display: flex;
    flex-direction: column;
    padding: 1.25rem;
    flex-grow: 1;
  }

  .card-specs {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-bottom: 0.5rem;
  }

  .card-purity {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--color-primary-light);
    background: rgba(212, 166, 84, 0.15);
    border: 1px solid rgba(212, 166, 84, 0.25);
    padding: 0.1rem 0.5rem;
    border-radius: var(--radius-full);
  }

  .card-cas {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-text-muted);
    background: var(--color-bg-deep);
    padding: 0.1rem 0.5rem;
    border-radius: var(--radius-full);
  }

  .card-title {
    font-size: 1.375rem;
    font-weight: 600;
    margin-bottom: 0.25rem;
    line-height: 1.2;
  }

  .card-title a {
    color: var(--color-text);
  }

  .card-title a:hover {
    color: var(--color-primary-light);
  }

  .card-botanical {
    font-size: 0.8rem;
    font-style: italic;
    color: var(--color-text-muted);
    font-family: var(--font-display);
    margin-bottom: 0.75rem;
  }

  .card-desc {
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    line-height: 1.5;
    margin-bottom: 1.5rem;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: auto;
    gap: 0.5rem;
  }

  .card-footer .btn {
    flex-grow: 1;
    text-align: center;
  }

  /* ── Empty State ── */
  .empty-state {
    text-align: center;
    padding: 4rem 2rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    max-width: 500px;
    margin: 3rem auto;
  }

  .empty-icon {
    font-size: 3rem;
    margin-bottom: 1rem;
  }

  .empty-state h3 {
    font-size: 1.5rem;
    margin-bottom: 0.5rem;
  }

  .empty-state p {
    color: var(--color-text-secondary);
    margin-bottom: 1.5rem;
  }
</style>

<script>
  // Simple reactive frontend filter
  function initFilters() {
    const searchInput = document.getElementById('product-search') as HTMLInputElement;
    const categoryTabs = document.querySelectorAll('.category-tab');
    const productCards = document.querySelectorAll('.product-card');
    const emptyState = document.getElementById('empty-state');
    const grid = document.getElementById('products-grid');
    const countLabel = document.getElementById('products-count-label');
    const resetButton = document.getElementById('reset-filters');

    let currentSearch = '';
    let currentCategory = 'all';

    function filterProducts() {
      let visibleCount = 0;

      productCards.forEach((card) => {
        const name = card.getAttribute('data-name') || '';
        const cas = card.getAttribute('data-cas') || '';
        const desc = card.getAttribute('data-desc') || '';
        const cat = card.getAttribute('data-category') || '';

        const matchesSearch =
          name.includes(currentSearch) ||
          cas.includes(currentSearch) ||
          desc.includes(currentSearch);

        const matchesCategory = currentCategory === 'all' || cat === currentCategory;

        if (matchesSearch && matchesCategory) {
          (card as HTMLElement).style.display = 'flex';
          visibleCount++;
        } else {
          (card as HTMLElement).style.display = 'none';
        }
      });

      // Update count label
      if (countLabel) {
        countLabel.textContent = `Showing ${visibleCount} product${visibleCount === 1 ? '' : 's'}`;
      }

      // Handle empty state
      if (visibleCount === 0) {
        if (grid) grid.style.display = 'none';
        if (emptyState) emptyState.style.display = 'block';
      } else {
        if (grid) grid.style.display = 'grid';
        if (emptyState) emptyState.style.display = 'none';
      }
    }

    // Search event
    if (searchInput) {
      searchInput.addEventListener('input', (e) => {
        currentSearch = (e.target as HTMLInputElement).value.toLowerCase().trim();
        filterProducts();
      });
    }

    // Category click events
    categoryTabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        categoryTabs.forEach(t => t.classList.remove('active'));
        tab.classList.add('active');
        currentCategory = tab.getAttribute('data-category') || 'all';
        filterProducts();
      });
    });

    // Reset button
    if (resetButton) {
      resetButton.addEventListener('click', () => {
        if (searchInput) searchInput.value = '';
        currentSearch = '';
        categoryTabs.forEach(t => t.classList.remove('active'));
        const allTab = document.getElementById('btn-cat-all');
        if (allTab) allTab.classList.add('active');
        currentCategory = 'all';
        filterProducts();
      });
    }
  }

  // Support Astro transitions lifecycle
  initFilters();
  document.addEventListener('astro:page-load', initFilters);
</script>
